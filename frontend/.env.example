# Frontend contract: always call same-origin /api.
NEXT_PUBLIC_BACKEND_URL=/api

# Next route-handler proxy target for /api in local/dev.
# Defaults to the AWS dev backend if unset.
# Example local backend target: http://127.0.0.1:3000
DEV_BACKEND_ORIGIN=http://fefeave-backend-dev-379356847.us-west-2.elb.amazonaws.com

# Optional dev auth token forwarded as:
# Authorization: Bearer <DEV_AUTH_BEARER>
# DEV_AUTH_BEARER=
