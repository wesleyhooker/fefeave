# Frontend contract: always call same-origin /api.
NEXT_PUBLIC_BACKEND_URL=/api

# Backend API base URL used by server-side BFF/auth routes.
BACKEND_BASE_URL=http://localhost:3000/api

# Cognito Hosted UI OAuth (Authorization Code flow).
COGNITO_DOMAIN=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_REDIRECT_URI=http://localhost:3001/api/auth/callback
COGNITO_LOGOUT_URI=http://localhost:3001/login

# Session cookie signing secret (HMAC SHA-256).
AUTH_SESSION_SECRET=

# --- Local dev only: authenticated Playwright screenshots (see docs/DEV.md) ---
# Never enable in production. Requires local backend AUTH_MODE=dev_bypass (e.g. make dev).
# AUTH_DEV_BOOTSTRAP_ENABLED=1
# AUTH_DEV_BOOTSTRAP_SECRET=
