# Frontend contract: always call same-origin /api.
NEXT_PUBLIC_BACKEND_URL=/api

# Backend API base URL used by server-side BFF/auth routes.
BACKEND_BASE_URL=http://localhost:3001/api

# Cognito Hosted UI OAuth (Authorization Code flow).
COGNITO_DOMAIN=your-domain.auth.us-east-1.amazoncognito.com
COGNITO_CLIENT_ID=your_client_id
COGNITO_CLIENT_SECRET=your_client_secret
COGNITO_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Session cookie signing secret (HMAC SHA-256).
AUTH_SESSION_SECRET=replace_with_a_long_random_secret
