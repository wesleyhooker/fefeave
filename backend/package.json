{
  "name": "fefeave-backend",
  "version": "1.0.0",
  "description": "Backend API for Fefeave reseller business system",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "build:lambda": "npm run build && bash scripts/verify-lambda-build.sh",
    "package:lambda": "bash scripts/package-lambda.sh",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest --ci --testPathIgnorePatterns=\"db-smoke|shows-integration|wholesalers-integration|owed-line-items-integration|settlement-ledger-integration|vendor-expense-ledger-integration|closed-show-freeze-integration|inventory-purchases-integration|business-expenses-integration|financial-strategy-integration|cash-snapshots-integration|financial-recommendations-integration|financial-events-integration|financial-events-dual-write-integration|financial-events-backfill-integration|event-derived-cash-parity-integration|financial-activity-integration|financial-event-summaries-integration|financial-obligation-projections-integration|financial-show-profit-integration|financial-statement-projections-integration|owner-weekly-payout-integration|owner-self-pay-activity-integration|portal-integration|exports-balances-csv\"",
    "test:integration": "bash scripts/run-integration-tests.sh",
    "test:integration:neon": "bash scripts/run-neon-integration-tests.sh",
    "migrate:up": "node-pg-migrate --tsx up -m migrations",
    "migrate:down": "node-pg-migrate --tsx down -m migrations",
    "migrate:create": "node-pg-migrate create -m migrations",
    "seed:dev": "tsx scripts/seed-dev.ts",
    "backfill:financial-events": "tsx scripts/backfill-financial-events.ts",
    "verify:owner-self-pay": "tsx scripts/verify-owner-self-pay.ts",
    "db:reset": "bash scripts/db-reset.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-secrets-manager": "^3.1055.0",
    "@aws-sdk/s3-presigned-post": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@fastify/aws-lambda": "^5.1.4",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/swagger": "^8.13.0",
    "@fastify/swagger-ui": "^2.1.0",
    "fastify": "^4.26.0",
    "fastify-plugin": "^4.5.1",
    "jose": "^5.2.0",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.18.0",
    "pino": "^9.2.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "archiver": "^7.0.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
